# Copy this file to .env and fill in your values.

# Required: token from @BotFather
BOT_TOKEN=

# Optional but recommended: your Telegram user id so only you can post.
# Run the bot and send /whoami to discover it.
OWNER_ID=

# Optional: where to store detected chats (defaults to bot_data.db)
DATABASE_NAME=bot_data.db

# Inline link buttons. Leave any blank to hide that button.
CHANNEL_URL=
WEBSITE_URL=
DONATIONS_URL=
CAM_ROOM_URL=
CONTACT_URL=
