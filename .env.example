# Copy this file to .env and fill in your values.

# Required: token from @BotFather (BOT_TOKEN or TELEGRAM_BOT_TOKEN both work)
BOT_TOKEN=

# Optional but recommended: your Telegram user id so only you can use /post.
# Run the bot and send /whoami to discover it.
OWNER_ID=

# Web dashboard
WEB_HOST=0.0.0.0
WEB_PORT=5000

# Default link-button URLs. Leave any blank to hide that button.
# (These can also be edited live from the web dashboard.)
CHANNEL_URL=
WEBSITE_URL=
DONATIONS_URL=
CAM_ROOM_URL=
CONTACT_URL=
